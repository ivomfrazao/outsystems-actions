{
  "manifest_version": 3,
  "name": "OutSystems Actions",
  "version": "1.1.0",
  "description": "Monitors OutSystems Service Center and LifeTime and notifies on relevant events such as deployments, publishes, and required interventions.",
  "permissions": [
    "notifications",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://*/ServiceCenter/*",
    "*://*/LifeTime/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/ServiceCenter/*",
        "*://*/LifeTime/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "sounds/notification.wav"
      ],
      "matches": [
        "*://*/ServiceCenter/*",
        "*://*/LifeTime/*"
      ]
    }
  ]
}
